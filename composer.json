{
    "name": "rubricate/arr",
    "description": "A lightweight and strict-typed array manipulation component.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Estefanio N Santos",
            "email": "estefanions@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "keywords": [
        "rubricate",
        "arr",
        "array",
        "matrix",
        "utilities",
        "strict-types"
    ],
    "support": {
        "docs": "https://rubricate.github.io/components/arr",
        "source": "https://github.com/rubricate/arr",
        "issues": "https://github.com/rubricate/arr/issues"
    },
    "autoload": {
        "psr-4": {
            "Rubricate\\Arr\\": "Rubricate/Arr/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    }
}
